# myBeez — environment variables (example)
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ---- Required ----
DATABASE_URL=postgres://user:password@localhost:5432/mybeez
SESSION_SECRET=change-me-in-prod-must-be-long-and-random

# ---- Tenancy (PR #7) ----
# Comma-separated list of root domains. Anything matching `<sub>.<root>` is
# resolved as `tenantService.getBySlug(<sub>)`. Anything else is a custom
# domain and looked up in the `tenant_domains` table.
ROOT_DOMAINS=mybeez-ai.com,localhost

# ---- Superadmin (PR #5, temporary) ----
# Bearer token guarding /api/tenants. Must be ≥16 chars. Without it,
# admin routes respond 503. Will be replaced by nominative auth + RBAC
# in the upcoming auth PRs.
SUPERADMIN_TOKEN=

# ---- AI providers (Alfred) ----
# At least one must be set. Order of preference: OpenAI > Gemini > Grok.
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# ---- Auth nominative (PR #12) ----
# Resend API key for transactional emails (verify, password reset).
# If absent, emails are logged to stdout instead of sent (dev mode).
RESEND_API_KEY=
# From address for outbound emails. Default `myBeez <noreply@mybeez-ai.com>`.
MAIL_FROM=
# Base URL used to build email links (verify / reset). Falls back to the
# request's host in dev. MUST be set in prod (https://app.mybeez-ai.com).
APP_BASE_URL=

# ---- Backups (R2) ----
# Cloudflare R2 endpoint = https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=r2mybeez
R2_PREFIX=mybeezdb/
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional. Default 30. Only positive integers.
BACKUP_RETENTION_DAYS=30

# ---- Optional ----
# PORT=3000
