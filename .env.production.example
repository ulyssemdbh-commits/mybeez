# myBeez — production environment template.
# On the deploy host: cp .env.production.example .env.production, fill in the
# blanks, then `docker compose up -d --build`. NEVER commit .env.production.
#
# Generate strong secrets with: openssl rand -base64 32

# ---- Postgres (read by both `db` and `app` services) ----
POSTGRES_DB=mybeez
POSTGRES_USER=mybeez
POSTGRES_PASSWORD=

# ---- App: database connection ----
# Hostname `db` resolves to the compose service. Password MUST match
# POSTGRES_PASSWORD above (same value, two readers).
DATABASE_URL=postgresql://mybeez:CHANGE_ME@db:5432/mybeez

# ---- Sessions ----
SESSION_SECRET=

# ---- Tenants ----
ROOT_DOMAINS=mybeez-ai.com,localhost
APP_BASE_URL=https://mybeez-ai.com

# ---- Superadmin (temporary, until full RBAC) ----
# Bearer token guarding /api/tenants. Must be ≥16 chars.
SUPERADMIN_TOKEN=

# ---- Auth emails (Resend) ----
# Without RESEND_API_KEY, emails are logged to stdout (no sends).
RESEND_API_KEY=
# Default `myBeez <noreply@mybeez-ai.com>` if unset.
MAIL_FROM=

# ---- Backups (Cloudflare R2) ----
R2_ENDPOINT=https://c6d762e456464de419619694dfa83b8d.r2.cloudflarestorage.com
R2_BUCKET=r2mybeez
R2_PREFIX=mybeezdb/
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
BACKUP_RETENTION_DAYS=30

# ---- AI providers (at least one required for Alfred) ----
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# ---- OCR PDF via ulysseclaude (fix/invoice-parse-via-ulysseclaude) ----
# myBeez délègue le parsing PDF des factures à ulysseclaude
# (pdf-parse + Gemini 2.5 Flash texte + fallback OpenAI gpt-4.1-mini).
# Path image (jpeg/png/webp) reste local indépendamment.
# Le path PDF répond 503 si ULYSSECLAUDE_PARSE_TOKEN est absent.
ULYSSECLAUDE_PARSE_URL=https://moe.ulyssepro.org/api/external/parse-invoice
ULYSSECLAUDE_PARSE_TOKEN=

# ---- Misc ----
NODE_ENV=production
PORT=3000
